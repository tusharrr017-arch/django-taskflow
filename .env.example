# Django backend environment variables
# Copy this file to .env in the project root and fill in values.
# Note: settings.py must be updated to read these variables before they take effect.

# Required for production — generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames (no spaces)
# Example: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional — for future PostgreSQL migration (not used by default settings)
# DATABASE_URL=postgres://user:password@localhost:5432/taskmanagement

# Optional — restrict CORS in production (not used by default settings)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
