# Django backend environment variables
# Copy this file to .env in the project root for local development.

# Generate a production value with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-change-before-production

# Set to False on Render/production
DEBUG=True

# Comma-separated hostnames (no spaces)
# Local: localhost,127.0.0.1
# Render: add your Render hostname, e.g. taskflow-api.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins allowed to call the API (no spaces)
# Local Vite defaults:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (Render/production) — omit for local SQLite development
# DATABASE_URL=postgres://user:password@host:5432/dbname
